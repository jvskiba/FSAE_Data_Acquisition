def process_gui_queue():
    latest_telem = None
    global last_update
    try:
        while True:
            kind, payload = controller.gui_queue.get_nowait()
            
            if kind == "log":
                #self.text_console.insert(tk.END, payload + "\n")
                #self.text_console.see(tk.END)
                continue
            elif kind == "status":
                print("!!! Check - GUI Status")
                #self.status_label.config(text=payload)
            elif kind == "telem_data":
                # keep only the newest telem row
                latest_telem = payload
                
    except queue.Empty:
        pass

    # Update only the newest telem_data row if there was one
    if latest_telem or (time.monotonic() - last_update) > 1.0:
        update(controller.signals.get_latest_telem())
        last_update = time.monotonic()

    # reschedule
    if controller.running:
        root.after(50, process_gui_queue)

